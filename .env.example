# Google Search Console verification
# Get from: Search Console > Settings > Ownership verification > HTML tag
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Analytics — fill in whichever you use (or both)
# Plausible: your site domain, e.g. uinuxblog.getuinux.com
PUBLIC_PLAUSIBLE_DOMAIN=

# Fathom: your site ID from Fathom dashboard (e.g. ABCDEFGH)
PUBLIC_FATHOM_SITE_ID=
